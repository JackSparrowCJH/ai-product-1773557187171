.container { display:flex; flex-direction:column; align-items:center; padding-top:80rpx; }
.merit-display { font-size:48rpx; color:#ffd700; margin-bottom:20rpx; }
.combo { font-size:36rpx; color:#ff6b6b; margin-bottom:10rpx; }
.fish-wrapper { position:relative; width:400rpx; height:400rpx; margin:40rpx 0; }
.fish { width:100%; height:100%; transition:transform 0.08s; }
.tap-anim { transform:scale(0.9); }
.float-text { position:absolute; color:#ffd700; font-size:32rpx; animation:floatUp 0.6s ease-out forwards; pointer-events:none; }
@keyframes floatUp { 0%{opacity:1;transform:translateY(0)} 100%{opacity:0;transform:translateY(-80rpx)} }
.bottom-bar { display:flex; gap:30rpx; margin-top:60rpx; }
.btn { background:#333; color:#ffd700; padding:16rpx 40rpx; border-radius:40rpx; font-size:28rpx; border:none; }

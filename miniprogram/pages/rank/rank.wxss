.container { padding:40rpx; }
.title { font-size:40rpx; color:#ffd700; text-align:center; margin-bottom:40rpx; }
.rank-item { display:flex; align-items:center; padding:20rpx 0; border-bottom:1rpx solid #333; }
.rank-no { width:60rpx; font-size:36rpx; color:#ffd700; }
.rank-name { flex:1; font-size:30rpx; }
.rank-merit { font-size:28rpx; color:#aaa; }
.empty { text-align:center; color:#666; margin-top:100rpx; }
